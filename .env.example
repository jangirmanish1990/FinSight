# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── LangSmith observability ───────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=finsight
LANGCHAIN_API_KEY=ls__...

# ── Database (SQLite — path relative to backend/) ────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./finsight.db

# ── ChromaDB (embedded, no server needed) ────────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── Tools / MCP ───────────────────────────────────────────────────────────────
BRAVE_API_KEY=BSA...
# EDGAR MCP runs as a local process — no key needed for free tier

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set this to your Render backend URL after deployment
# Local dev: leave as-is (Vite proxy handles /api → :8000)
VITE_API_URL=http://localhost:8000

# ── Optional: OpenAI embeddings (text-embedding-3-small) ─────────────────────
OPENAI_API_KEY=sk-...

# ── App settings ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=10

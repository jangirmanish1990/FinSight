{
  "version": "2.0.0",
  "tasks": [

    // ── Dev servers ────────────────────────────────────────────────────────
    {
      "label": "🚀 dev: backend",
      "type": "shell",
      "command": "uv run uvicorn main:app --reload --host 0.0.0.0 --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "🎨 dev: frontend",
      "type": "shell",
      "command": "pnpm dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "build",
      "presentation": { "panel": "dedicated", "reveal": "always" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "⚡ dev: start both servers",
      "dependsOn": ["🚀 dev: backend", "🎨 dev: frontend"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },

    // ── Database ───────────────────────────────────────────────────────────
    {
      "label": "🗄️ db: init",
      "type": "shell",
      "command": "uv run python scripts/init_db.py",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "🗄️ db: reset",
      "type": "shell",
      "command": "Remove-Item -ErrorAction SilentlyContinue finsight.db, finsight.db-shm, finsight.db-wal; uv run python scripts/init_db.py",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },

    // ── Install ────────────────────────────────────────────────────────────
    {
      "label": "📦 install: backend",
      "type": "shell",
      "command": "uv sync",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "📦 install: frontend",
      "type": "shell",
      "command": "pnpm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "📦 install: everything",
      "dependsOn": ["📦 install: backend", "📦 install: frontend"],
      "problemMatcher": []
    },

    // ── Tests ──────────────────────────────────────────────────────────────
    {
      "label": "🧪 test: backend",
      "type": "shell",
      "command": "uv run pytest tests/ -v --tb=short",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": "test",
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "🧪 test: frontend",
      "type": "shell",
      "command": "pnpm vitest run",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "group": "test",
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "🧪 test: all",
      "dependsOn": ["🧪 test: backend", "🧪 test: frontend"],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },

    // ── Lint ───────────────────────────────────────────────────────────────
    {
      "label": "🔍 lint: backend (ruff)",
      "type": "shell",
      "command": "uv run ruff check . --fix && uv run ruff format .",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "🔍 lint: frontend (eslint)",
      "type": "shell",
      "command": "pnpm eslint src/ --fix && pnpm prettier --write src/",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    },

    // ── RAG ────────────────────────────────────────────────────────────────
    {
      "label": "📚 rag: ingest documents",
      "type": "shell",
      "command": "uv run python agents/rag/ingest.py",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "presentation": { "panel": "shared", "reveal": "always" },
      "problemMatcher": []
    }
  ]
}
